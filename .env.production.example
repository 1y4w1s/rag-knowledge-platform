# 睿阁（Ruige）— 生产环境变量模板
# 用法：
#   1. 复制为 .env
#   2. 填入真实密钥（所有 `changeme` 值必须替换）
#   3. 执行 chmod 600 .env（Unix）或 icacls .env /inheritance:r /grant "%USERNAME%:F"（Windows）
#   4. 确保 .env 在 .gitignore 中（已在）
#
# 安全要求（甲方 IT 审计）：
#   ✅ POSTGRES_PASSWORD / JWT_SECRET 必须 ≥ 32 位随机字符
#   ✅ DEEPSEEK_API_KEY / TONGYI_API_KEY 不能是公共测试 Key
#   ❌ 永远不要将 .env 提交到 Git
#   ❌ 永远不要在前端代码中引用这些值

# --- PostgreSQL（Docker Compose 自动加载）---
POSTGRES_PASSWORD=changeme
# api 容器内由 docker-compose.yml 覆盖为 postgres 主机名；本机 venv 连 Docker 库时用 localhost：
DATABASE_URL=postgresql+asyncpg://ruige:${POSTGRES_PASSWORD:-changeme}@localhost:5432/ruige

# --- JWT 鉴权（生产必须改为长随机串）---
JWT_SECRET=changeme

# --- LLM / 嵌入 API Key（仅服务端读取）---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
TONGYI_API_KEY=
TONGYI_BASE_URL=https://dashscope.aliyuncs.com
EMBEDDING_PROVIDER=tongyi
EMBEDDING_MODEL=text-embedding-v2
RE_EMBED_TOKEN=

# --- Rerank ---
RERANK_ENABLED=true
RERANK_PROVIDER=tongyi
RERANK_MODEL=qwen3-rerank
RERANK_INPUT_TOP_N=20

# --- 文件存储 ---
UPLOAD_DIR=./uploads
UPLOAD_MAX_BYTES=20971520

# --- 大表 / 跨页表格（B2：默认开；异常时可关≈F3）---
# TABLE_CHUNK_SPLIT_ENABLED=true
# TABLE_PARENT_MAX_CHARS=8000
# TABLE_ROW_OVERLAP=1

# --- 前端跨域（生产改为实际域名/IP）---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- 弹性配置（可覆盖默认值）---
# LLM_TIMEOUT_SECONDS=120.0
# RETRY_MAX_ATTEMPTS=2
# CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# DEGRADATION_COOLDOWN_SECONDS=60
# HTTP_MAX_CONNECTIONS=10
