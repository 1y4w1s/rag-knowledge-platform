# 知岸（Zhian）— 生产 / 内网部署环境变量模板
# 用法：
#   1. 复制为 .env：  Copy-Item .env.production.example .env
#   2. 填入下方「必改项」的真实值（.env 已在 .gitignore，不会进 Git）
#   3. 按 docs/DEPLOY.md 启动：docker compose up -d --build
#
# ⚠️ 本模板面向 HTTP 内网部署（无 TLS）。勿将含真实密钥的 .env 提交到 Git。

# --- 必改项（部署前必须替换）---

# Postgres 容器密码；docker-compose.yml 会用它拼 DATABASE_URL
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_random_password

# JWT 签名密钥；至少 32 位随机字符串；泄露则任何人可伪造登录 token
JWT_SECRET=CHANGE_ME_use_a_long_random_string_at_least_32_chars

# DeepSeek 对话 API（服务端读取，前端永不接触）
DEEPSEEK_API_KEY=sk-your-deepseek-key

# 阿里云通义千问 — 生产嵌入（EMBEDDING_PROVIDER=tongyi 时必填）
TONGYI_API_KEY=sk-your-tongyi-key

# --- 数据库连接 ---

# docker compose 启动时，api 容器内 DATABASE_URL 由 compose 覆盖为 postgres 主机名。
# 若本机 venv 直连同一 Docker 库，用 localhost：
DATABASE_URL=postgresql+asyncpg://zhiku:CHANGE_ME_use_a_strong_random_password@localhost:5432/zhiku

# --- LLM / 嵌入（一般保持默认）---

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
EMBEDDING_PROVIDER=tongyi

# --- 文件存储 ---

# 生产 compose（docker-compose.prod.yml）会覆盖为 /app/uploads 并挂载命名卷 uploads_data
UPLOAD_DIR=/app/uploads

# --- 前端跨域（CORS）---

# 填用户浏览器实际访问前端的 origin（协议 + 主机 + 端口），逗号分隔，无尾斜杠。
# 内网示例（按你的服务器 IP 改）：
#   仅 API 探活、暂不接前端：http://localhost:5173
#   前端在同机 Vite 预览：http://192.168.1.100:5173
#   生产 web（EW-B4 · nginx:80）：http://192.168.1.100
CORS_ORIGINS=http://192.168.1.100,http://localhost
