# 知岸（Zhian）— 环境变量模板
# 用法：复制为 .env 并填入真实值（.env 已在 .gitignore，不会进 Git）

# --- 数据库（Docker compose 默认）---
POSTGRES_PASSWORD=changeme
# api 容器内由 docker-compose.yml 覆盖为 postgres 主机名；本机 venv 连 Docker 库时用 localhost 这行：
DATABASE_URL=postgresql+asyncpg://zhiku:changeme@localhost:5432/zhiku

# --- 鉴权（Wave 1 注册登录时使用）---
JWT_SECRET=replace-with-a-long-random-string

# --- LLM / 嵌入 API（仅服务端读取，前端永不接触）---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
TONGYI_API_KEY=
EMBEDDING_PROVIDER=tongyi
EMBEDDING_MODEL=text-embedding-v2
# 运维全库重嵌 API（空=禁用 POST /api/v1/internal/re-embed）
RE_EMBED_TOKEN=

# --- 检索 rerank（Plan-RAG R3-2）---
RERANK_ENABLED=true
RERANK_PROVIDER=tongyi
RERANK_MODEL=qwen3-rerank
RERANK_INPUT_TOP_N=20

# --- 文件存储 ---
UPLOAD_DIR=./uploads

# --- 前端跨域（Wave 4 本地 Vite 默认 5173）---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
